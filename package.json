{
  "name": "march-madness-2026",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.dev.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "analyze": "node --require tsx/cjs scripts/analysis/analyze.cjs",
    "collision-stats": "node --require tsx/cjs scripts/analysis/collision-stats.cjs",
    "bracket-stats": "node --require tsx/cjs scripts/bracket-stats.cjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "next": "16.1.7",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "vitest": "^3.1.1",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
